# Copy this file to .env.local and fill in your values
# Get these from: Supabase → Project Settings → API

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...   # "publishable" key — used by Vercel functions
SUPABASE_SERVICE_KEY=sb_secret_...     # "secret" key     — used only by migrate script locally
SUPABASE_ACCESS_TOKEN=sbp_...          # personal access token — used by scripts/sql.js
